# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS Y API
# ==========================================
DATABASE_URI=postgresql://user:password@localhost:5432/database_name
SECRET_KEY=generate-with-secrets-token-urlsafe-32
TOTP_ENCRYPTION_KEY=generate-with-secrets-token-urlsafe-32
# Clave para encriptar campos sensibles (IBAN, Saltra, backup codes 2FA)
# Puede ser la misma que TOTP_ENCRYPTION_KEY o una independiente
FIELD_ENCRYPTION_KEY=generate-with-secrets-token-urlsafe-32

# ==========================================
# GEMINI API KEYS (Sistema de Fallback)
# ==========================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY_2=your-backup-gemini-api-key-here
GEMINI_API_KEY_3=

# ==========================================
# RUTAS DE ARCHIVOS (Opcional - usa defaults si no se especifica)
# ==========================================
# RUTA_RAIZ_NOTIFICACIONES=/path/to/storage
# RUTA_INBOX=/path/to/storage/__INBOX_NO_CLASIFICADOS
# BACKUP_DIR=/path/to/backups

# ==========================================
# CONFIGURACIÓN DE EMAIL (SMTP)
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=your-email@gmail.com

# ==========================================
# SISTEMA (Redis y Entorno)
# ==========================================
REDIS_URL=redis://localhost:6379/0
FLASK_ENV=development
FRONTEND_URL=http://localhost:3000

# ==========================================
# SALTRA DEHU (API Externa)
# ==========================================
SALTRA_EMAIL=your-saltra-email@example.com
SALTRA_PASSWORD=your-saltra-password
SALTRA_CERT_SECRET=your-saltra-cert-secret

# ==========================================
# BASE URL
# ==========================================
BASE_URL=http://localhost:5000

# ==========================================
# CONFIGURACIÓN DE BACKUPS
# ==========================================
BACKUP_DIR=./backups
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=gestion_db
DB_PASSWORD=your-db-password

# ==========================================
# CONFIGURACIÓN DE LOGGING
# ==========================================
DEBUG=True
LOG_LEVEL=DEBUG
LOG_TO_FILE=False
LOG_FILE=logs/app.log

# ==========================================
# PUSH NOTIFICATIONS (VAPID)
# ==========================================
# Generate with: python backend/scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CLAIM_EMAIL=admin@your-domain.com
